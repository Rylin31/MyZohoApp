				displayname = "Appointment"
				values  = appointment.ID
    			displayformat = [appointment_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			subjective
			(
    			type = textarea
				displayname = "Subjective"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			objective
			(
    			type = textarea
				displayname = "Objective"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			assessment
			(
    			type = textarea
				displayname = "Assessment"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			plan
			(
    			type = textarea
				displayname = "Plan"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			entered_by
			(
				type = list	
				displayname = "Entered By"
				values  = doctor_profile.ID
    			displayformat = [doctor_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			entry_date
			(
    			type = date
				displayname = "Entry Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			entry_time
			(
    			type = time
				displayname = "Entry Time"
				timedisplayoptions = "hh:mm:ss" 
	 			row = 1
	 			column = 1   
				width = medium
			)
			last_updated
			(
    			type = datetime
				displayname = "Last Updated"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Appointment Scheduled","Patient Checked In","Appointment Rescheduled","Appointment Cancelled","Consultation In Progress","SOAP Note Created","Diagnosis Confirmed","Further Testing Required","Prescription Issued","Follow-Up Scheduled","Test Results Received","Test Scheduled","Medication Dispensed","Prescription Revised","Patient Monitoring Active","Follow-Up Completed","Follow-Up Rescheduled","Follow-Up Cancelled","Care Plan Updated","Patient Discharged","Emergency Alert Triggered","Case Closed","Emergency Response Initiated","Patient Stabilized","Patient Transferred"}
			}
		}
	}
	reports
	{
		list messaging_Report
		{
			displayName = "All Messages"
			show all rows from messaging    
			(
				sender_1 as "Sender"
				recipient as "Recipient"
				appointment as "Appointment"
				subject_1 as "Subject"
				body as "Body"
				sent_at as "Sent At"
				read_status as "Read Status"
				encryption_status as "Encryption Status"
				message_type as "Message Type"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (message_type == "Doctor To Patient")
				fields = [message_type]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (message_type == "System Alert")
				fields = [message_type]
				format = "color:#000000;background-color:#1bbc9b;"
				}
			)
		}
		kanban messaging_by_message_type
		{
			displayName = "Message Types"
			show all rows from messaging    
			(
				sender_1 as "Sender"
				recipient as "Recipient"
