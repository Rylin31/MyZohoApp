 application "Healthcare Management System"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "America/Los_Angeles"
 	time format = "24-hr"
 	forms
	{
		form appointment
		{
			displayname = "Appointment"
			success message = "Appointment Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			appointment_id
			(
    			type = autonumber
				displayname = "Appointment ID"
				start index = 1
	 			row = 1
	 			column = 1   
				width = medium
			)
			patient
			(
				type = list	
				displayname = "Patient"
				values  = patient_profile.ID
    			displayformat = [patient_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			doctor
			(
				type = list	
				displayname = "Doctor"
				values  = doctor_profile.ID
    			displayformat = [doctor_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			scheduled_date
			(
    			type = date
				displayname = "Scheduled Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			scheduled_time
			(
    			type = time
				displayname = "Scheduled Time"
				timedisplayoptions = "hh:mm:ss" 
	 			row = 1
	 			column = 1   
				width = medium
			)
			duration
			(
				type = number
				displayname = "Duration"
				maxchar = 19
	 			row = 1
	 			column = 1   
				width = medium
			)
			status
			(
				type = picklist
				displayname = "Status"
				values = {"Confirmed","Canceled","Rescheduled","Pending"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			reason_for_visit
			(
    			type = textarea
				displayname = "Reason For Visit"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			location
			(
    			type = address
				displayname = "Location"
     			capture_coordinates = true
     			adjust_using_map = false
     			address_line_1
     			(
	     			  type = address_line_1
	     			  displayname = "Address Line 1"
     			) 
     			address_line_2
     			(
	     			  type = address_line_2
	     			  displayname = "Address Line 2"
	     			 visibility = false
     			) 
     			district_city
     			(
	     			  type = district_city
	     			  displayname = "City / District"
	     			 visibility = false
     			) 
     			state_province
     			(
	     			  type = state_province
	     			  displayname = "State / Province"
	     			 visibility = false
     			) 
     			postal_Code
     			(
	     			  type = postal_Code
	     			  displayname = "Postal Code"
	     			 visibility = false
     			) 
     			country
     			(
	     			  type = country
	     			  displayname = "Country"
	     			 visibility = false
     			) 
     			latitude
     			(
	     			  type = latitude
	     			  displayname = "Latitude"
	     			 visibility = false
     			) 
     			longitude
     			(
	     			  type = longitude
	     			  displayname = "Longitude"
	     			 visibility = false
     			) 
	 			row = 1
	 			column = 1   
				width = medium
			)
			notes
			(
    			type = textarea
				displayname = "Notes"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Appointment Created","Appointment Confirmed","Appointment Pending Confirmation","Appointment Cancelled","Appointment In Progress","Appointment Rescheduled","Appointment Completed","Appointment Closed","Appointment Follow-Up Required"}
			}
