		list appointment_Report
		{
			displayName = "All Appointments"
			show all rows from appointment    
			(
				appointment_id as "Appointment ID"
				patient as "Patient"
				doctor as "Doctor"
				scheduled_date as "Scheduled Date"
				scheduled_time as "Scheduled Time"
				duration as "Duration"
				status as "Status"
				reason_for_visit as "Reason For Visit"
